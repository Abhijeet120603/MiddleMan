/**
  * @brief  Function implementing the TempCheckTask thread.
  * @param  argument: Not used
  * @retval None
  */
/* USER CODE END Header_StartTempCheck */
void StartTempCheck(void *argument)
{
  /* USER CODE BEGIN 5 */
  /* Infinite loop */
  for(;;)
  {
	  CurrentTemp = (CurrentTemp + 1) ? (CurrentTemp < 35) : 25;
	  printf("[current_temp] = %d \n\r", CurrentTemp);
      osDelay(1000);
  }
  /* USER CODE END 5 */
}

/* USER CODE BEGIN Header_StartFanCtrl */
/**
* @brief Function implementing the FanCtrlTask thread.
* @param argument: Not used
* @retval None
*/
/* USER CODE END Header_StartFanCtrl */
void StartFanCtrl(void *argument)
{
  /* USER CODE BEGIN StartFanCtrl */
  /* Infinite loop */
  for(;;)
  {
	  if (CurrentTemp < 30){
		  printf("fan off \n");
	  }
	  else{
		  printf("fan on \n");
	  }
    osDelay(1000);
  }
  /* USER CODE END StartFanCtrl */
}

